<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__col">
        <h4 class="footer__heading">{{ t.footerProducts }}</h4>
        <ul class="footer__links">
          {% for cat in products.categories %}
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}products/#cat-{{ cat.id }}">{{ cat.nameEn if langCode == 'en' else cat.name }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{{ t.footerCases }}</h4>
        <ul class="footer__links">
          {% for sol in cases.solutions %}
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}cases/#case-{{ sol.oid }}">{{ sol.nameEn if langCode == 'en' else sol.name }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{{ t.footerNews }}</h4>
        <ul class="footer__links">
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}news/">{{ t.allNews }}</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{{ t.footerAbout }}</h4>
        <ul class="footer__links">
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/">{{ t.companyIntro }}</a></li>
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/#honor">{{ t.honor }}</a></li>
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/#history">{{ t.history }}</a></li>
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/#join">{{ t.join }}</a></li>
          <li><a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/#contact">{{ t.contact }}</a></li>
        </ul>
      </div>

      <div class="footer__col footer__col--contact">
        <h4 class="footer__heading">{{ site.name }}</h4>
        <div class="footer__contact">
          <p>📞 {{ t.phoneLabel }}：{{ site.contact.phone }}</p>
          <p>📧 {{ site.contact.email }}</p>
          <p>🕐 {{ t.hoursLabel }}</p>
          <p>📍 {{ site.contact.address }}</p>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>{{ t.copyright }}</p>
      <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">{{ site.icp }}</a></p>
    </div>
  </div>
</footer>
