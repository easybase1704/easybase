<div class="lang-bar">
  <div class="container lang-bar__inner">
    {% if site.contact.phone %}<span class="lang-bar__phone">📞 {{ site.contact.phone }}</span>{% endif %}
    <div class="lang-bar__switcher">
      {% for l in langs %}
        {% if l.code == langCode %}
          <span class="lang-bar__link lang-bar__link--active">{{ l.flag }} {{ l.label }}</span>
        {% else %}
          {% if l.code == 'en' %}
            <a href="{{ site.basePath }}/en{{ page.url }}" class="lang-bar__link">{{ l.flag }} {{ l.label }}</a>
          {% else %}
            <a href="{{ site.basePath }}{{ page.url | replace('/en/', '/') }}" class="lang-bar__link">{{ l.flag }} {{ l.label }}</a>
          {% endif %}
        {% endif %}
        {% if not loop.last %}<span class="lang-bar__sep">|</span>{% endif %}
      {% endfor %}
    </div>
  </div>
</div>
