<header class="header" id="header">
  <nav class="nav container">
    <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}" class="nav__logo">
      <img src="{{ site.basePath }}/images/logo.webp" alt="{{ site.name }}" class="nav__logo-img">
    </a>

    <button class="nav__toggle" id="navToggle" aria-label="Menu">
      <span></span><span></span>
    </button>

    <ul class="nav__menu" id="navMenu">
      <li class="nav__item">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}" class="nav__link {% if activePage == 'home' %}active{% endif %}">{{ t.home }}</a>
      </li>

      <!-- 产品中心 下拉 -->
      <li class="nav__item nav__item--dropdown">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}products/" class="nav__link {% if activePage == 'products' %}active{% endif %}">{{ t.products }} ▾</a>
        <div class="nav__dropdown">
          <div class="nav__dropdown-inner">
            {% for cat in products.categories %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}products/#cat-{{ cat.id }}" class="nav__dropdown-link{% if loop.index > 4 %} nav__dropdown-link--extra{% endif %}">{{ cat.nameEn if langCode == 'en' else cat.name }}</a>
            {% endfor %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}products/" class="nav__dropdown-link nav__dropdown-link--all">{% if langCode == 'zh' %}查看全部产品 →{% else %}View All Products →{% endif %}</a>
          </div>
        </div>
      </li>

      <!-- 行业方案 下拉 -->
      <li class="nav__item nav__item--dropdown">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}cases/" class="nav__link {% if activePage == 'cases' %}active{% endif %}">{{ t.cases }} ▾</a>
        <div class="nav__dropdown">
          <div class="nav__dropdown-inner">
            {% for sol in cases.solutions %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}cases/{{ sol | caseSlug }}/" class="nav__dropdown-link{% if loop.index > 4 %} nav__dropdown-link--extra{% endif %}">{{ sol.nameEn if langCode == 'en' else sol.name }}</a>
            {% endfor %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}cases/" class="nav__dropdown-link nav__dropdown-link--all">{% if langCode == 'zh' %}查看全部方案 →{% else %}View All Solutions →{% endif %}</a>
          </div>
        </div>
      </li>

      <!-- 新闻 下拉 -->
      <li class="nav__item nav__item--dropdown">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}news/" class="nav__link {% if activePage == 'news' %}active{% endif %}">{{ t.news }} ▾</a>
        <div class="nav__dropdown">
          <div class="nav__dropdown-inner">
            {% for article in news.articles | sort(attribute='date') | reverse %}
            {% if loop.index <= 4 %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}news/#article-{{ article.oid }}" class="nav__dropdown-link">{{ article.title | truncate(20) }}</a>
            {% endif %}
            {% endfor %}
            <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}news/" class="nav__dropdown-link nav__dropdown-link--all">{% if langCode == 'zh' %}查看全部新闻 →{% else %}View All News →{% endif %}</a>
          </div>
        </div>
      </li>

      <li class="nav__item">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}support/" class="nav__link {% if activePage == 'support' %}active{% endif %}">{{ t.support }}</a>
      </li>
      <li class="nav__item">
        <a href="{{ site.basePath }}/{{ 'en/' if langCode == 'en' }}about/" class="nav__link {% if activePage == 'about' %}active{% endif %}">{{ t.about }}</a>
      </li>
    </ul>

  </nav>
</header>
