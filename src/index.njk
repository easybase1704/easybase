---
layout: layout.njk
activePage: home
pagination:
  data: langs
  size: 1
  alias: lang
permalink: /{{ lang.prefix }}index.html
eleventyComputed:
  title: "{{ 'Home' if lang.code == 'en' else '首页' }}"
  description: "{{ 'EasyBase Technology — Industrial Computer, Cloud Terminal, Edge Computing Manufacturer' if lang.code == 'en' else '原基科技 — 工控机 · 云终端 · 边缘计算设备制造商，提供X86及国产平台全系列产品' }}"
---

{% set langCode = lang.code %}
{% set t = i18n[langCode] %}

<!-- Hero Slider -->
<div class="hero-slider" id="heroSlider">
  {% set banners = [
    { src: site.basePath + "/images/banner-home-1.webp", alt: "原基科技" },
    { src: site.basePath + "/images/banner-home-3.webp", alt: "原基科技" }
  ] %}
  {% for b in banners %}
  <div class="hero-slider__slide{% if loop.first %} active{% endif %}">
    <img src="{{ b.src }}" alt="{{ b.alt }}" class="hero-slider__img" loading="{{ 'eager' if loop.first else 'lazy' }}">
  </div>
  {% endfor %}

  <div class="hero-slider__overlay">
    <div class="container hero-slider__inner">
      <div class="hero-slider__actions">
        <a href="{{ site.basePath }}/{{ lang.prefix }}products/" class="btn btn--primary btn--lg">{{ t.browseProducts }}</a>
        <a href="{{ site.basePath }}/{{ lang.prefix }}about/#contact" class="btn btn--outline-light btn--lg">{{ t.contactUs }}</a>
      </div>
    </div>
  </div>

  <button class="hero-slider__arrow hero-slider__arrow--prev" aria-label="上一张">&#10094;</button>
  <button class="hero-slider__arrow hero-slider__arrow--next" aria-label="下一张">&#10095;</button>

  <div class="hero-slider__dots">
    {% for b in banners %}
    <button class="hero-slider__dot{% if loop.first %} active{% endif %}" data-index="{{ loop.index0 }}" aria-label="第{{ loop.index }}张"></button>
    {% endfor %}
  </div>
</div>

<!-- Product Categories -->
<section class="section">
  <div class="container">
    <h2 class="section__title">{{ t.products }}</h2>
    <p class="section__subtitle">{% if langCode == 'zh' %}7大产品线 · 70+ 款产品 · 覆盖全场景计算需求{% else %}7 Product Lines · 70+ Models · Full-Spectrum Computing{% endif %}</p>

    <div class="grid grid--4">
      {% for cat in products.categories %}
      <a href="{{ site.basePath }}/{{ lang.prefix }}products/#cat-{{ cat.id }}" class="category-card">
        <div class="category-card__icon">
          <img src="{{ site.basePath }}{{ cat | getCategoryThumb(products.products) }}" alt="{{ cat.name if langCode == 'zh' else cat.nameEn }}" loading="lazy">
        </div>
        <h3 class="category-card__title">{{ cat.nameEn if langCode == 'en' else cat.name }}</h3>
        <p class="category-card__sub">{{ cat.nameEn if langCode == 'en' else cat.nameEn }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Solutions -->
<section class="section">
  <div class="container">
    <h2 class="section__title">{{ t.cases }}</h2>
    <p class="section__subtitle">{% if langCode == 'zh' %}覆盖 8 大行业场景，提供端到端解决方案{% else %}8 Industry Solutions — End-to-End Delivery{% endif %}</p>

    <div class="grid grid--4">
      {% for sol in cases.solutions %}
      <a href="{{ site.basePath }}/{{ lang.prefix }}cases/#case-{{ sol.oid }}" class="solution-card">
        <div class="solution-card__thumb">
          <img src="{{ site.basePath }}{{ sol.thumb }}" alt="{{ sol.nameEn if langCode == 'en' else sol.name }}" loading="lazy">
        </div>
        <h3 class="solution-card__name">{{ sol.nameEn if langCode == 'en' else sol.name }}</h3>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- News -->
<section class="section section--alt">
  <div class="container">
    <h2 class="section__title">{% if langCode == 'zh' %}最新资讯{% else %}Latest News{% endif %}</h2>
    <p class="section__subtitle">{% if langCode == 'zh' %}公司动态与行业新闻{% else %}Company Updates & Industry News{% endif %}</p>

    <div class="grid grid--3">
      {% for article in news.articles | sort(attribute='date') | reverse %}
      {% if loop.index <= 3 %}
      <a href="{{ site.basePath }}/{{ lang.prefix }}news/#article-{{ article.oid }}" class="card">
        <div class="card__image">
          <img src="{{ site.basePath }}{{ article.img }}" alt="{{ article.title }}" loading="lazy" onerror="this.style.display='none'">
        </div>
        <div class="card__body">
          <span class="tag">
            {% for cat in news.categories %}
            {% if cat.id == article.classId %}{{ cat.nameEn if langCode == 'en' else cat.name }}{% endif %}
            {% endfor %}
          </span>
          <h3 class="card__title">{{ article.title }}</h3>
          <p class="card__text">{{ article.description | truncate(60) }}</p>
          <p class="card__text" style="margin-top:var(--space-sm)">{{ article.date }}</p>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>

    <div class="text-center mt-4">
      <a href="{{ site.basePath }}/{{ lang.prefix }}news/" class="btn btn--outline">{{ t.viewDetail if langCode == 'en' else '查看全部新闻' }}</a>
    </div>
  </div>
</section>

<!-- v20260616-2 手机导航优化版 -->
<!-- Contact -->
<section class="section section--dark" style="text-align:center">
  <div class="container container--narrow">
    <h2 class="section__title" style="color:var(--color-text-on-dark)">{{ t.contactUs }}</h2>
    <p class="section__subtitle" style="color:rgba(255,255,255,0.85);line-height:2;margin-bottom:var(--space-md)">
      📍 {{ site.contact.address }}<br>
      {% if site.contact.phone %}📞 {{ t.phoneLabel }}：{{ site.contact.phone }}<br>{% endif %}
      {% for s in site.contact.sales %}
      {{ s.title }}：{{ s.phone }} {{ s.name }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </p>
    <p style="color:rgba(255,255,255,0.7);font-size:var(--text-sm);margin-bottom:var(--space-lg)">
      📧 {{ t.emailBiz }}：{{ site.contact.email }}　|　📧 {{ t.emailHR }}：{{ site.contact.hrEmail }}<br>
      🕐 {{ t.hoursLabel }}
    </p>
    <a href="{{ site.basePath }}/{{ lang.prefix }}about/#contact" class="btn btn--primary">{{ t.learnMore }}</a>
  </div>
</section>

<style>
.hero-slider__actions {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-2xl) var(--space-lg);
  background: var(--color-bg);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: all var(--transition-base);
}

.category-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--color-primary);
}

.category-card__icon {
  width: 100%;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-xs);
  background: #fff;
}

.category-card__icon img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.category-card__title {
  font-size: var(--text-lg);
  color: var(--color-text);
  font-weight: var(--font-semibold);
}

.category-card__sub {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}

/* Solutions card */
.solution-card {
  display: block;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  border: 1px solid var(--color-border-light);
  transition: all var(--transition-base);
}

.solution-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--color-primary);
}

.solution-card__thumb {
  width: 100%;
  aspect-ratio: 16/10;
  overflow: hidden;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-md);
}

.solution-card__thumb img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.solution-card__name {
  text-align: center;
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--color-text);
  padding: var(--space-md) var(--space-sm);
}

/* === 手机导航（内联保底，绕过CSS缓存） === */
@media (max-width: 1023px) {
  .header { height: 60px !important; }
  .nav__logo-img { height: 46px !important; }
  .nav__toggle { display: flex !important; }
  .nav__menu {
    position: fixed !important;
    top: 60px !important;
    left: 0 !important;
    right: 0 !important;
    background: #FFFAF5 !important;
    flex-direction: column !important;
    padding: 0 24px !important;
    gap: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    transition: max-height 0.35s ease !important;
    box-shadow: none !important;
    z-index: 99 !important;
  }
  .nav__menu.open {
    max-height: calc(100vh - 60px) !important;
    overflow-y: auto !important;
    padding: 20px 24px !important;
    gap: 4px !important;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
  }
  .nav__link { font-size: 18px !important; padding: 16px !important; width: 100% !important; text-align: center !important; border-bottom: 1px solid rgba(0,0,0,0.06) !important; }
}
</style>
